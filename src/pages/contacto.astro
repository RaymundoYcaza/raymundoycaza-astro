---
import Contactform from "@components/contactform.astro";
import Container from "@components/container.astro";
import Layout from "@layouts/Layout.astro";
import { Icon } from "astro-icon/components";
---

<Layout title="Contacto — Raymundo Ycaza">

  <!-- ═══ HERO ═══ -->
  <section class="max-w-4xl mx-auto mt-16 px-4 text-center">
    <p class="text-sm font-medium text-[#3C1475] uppercase tracking-widest mb-3">
      Hablemos
    </p>
    <h1 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight tracking-tight">
      ¿Tienes un proyecto en mente?<br />
      <span class="inline bg-[#3C1475] text-white px-2 py-1 box-decoration-clone rounded-sm leading-[1.4]">
        Cuéntame los detalles.
      </span>
    </h1>
    <p class="mt-5 text-lg text-slate-500 leading-relaxed max-w-2xl mx-auto">
      Ya sea una consulta, una colaboración o una pregunta puntual —
      respondo personalmente todos los mensajes en menos de 48 horas.
    </p>
  </section>

  <!-- ═══ CONTENIDO PRINCIPAL ═══ -->
  <Container>
    <div class="grid md:grid-cols-2 gap-10 mx-auto max-w-4xl mt-16">

      <!-- Columna izquierda -->
      <div class="flex flex-col gap-8">

        <!-- Para qué escribir -->
        <div>
          <h2 class="font-bold text-xl text-gray-900 mb-4">
            Puedo ayudarte con...
          </h2>
          <ul class="flex flex-col gap-3">
            {[
              "Automatizar un proceso en tu empresa",
              "Implementar una solución con Excel o herramientas no-code",
              "Una consultoría sobre flujos de trabajo",
              "Colaboraciones, prensa o apariciones en podcast",
              "Cualquier otra pregunta — si puedo ayudarte, lo hago",
            ].map((item) => (
              <li class="flex items-start gap-3 text-slate-600 text-sm">
                <svg class="w-4 h-4 text-[#3C1475] shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Datos de contacto -->
        <div>
          <h2 class="font-bold text-xl text-gray-900 mb-4">
            También puedes encontrarme en...
          </h2>
          <div class="flex flex-col gap-3">
            <div class="flex items-center gap-3 text-slate-600 text-sm">
              <Icon class="text-[#3C1475] w-4 h-4 shrink-0" name="uil:map-marker" />
              <span>Guayaquil, Ecuador</span>
            </div>
            <div class="flex items-center gap-3 text-sm">
              <Icon class="text-[#3C1475] w-4 h-4 shrink-0" name="uil:envelope" />
              <a
                href="mailto:ventas@raymundoycaza.com"
                class="text-[#3C1475] hover:text-[#0098ED] transition-colors">
                ventas@raymundoycaza.com
              </a>
            </div>
            <div class="flex items-center gap-3 text-sm">
              <Icon class="text-[#3C1475] w-4 h-4 shrink-0" name="uil:phone" />
              <a
                href="tel:+593959076237"
                class="text-[#3C1475] hover:text-[#0098ED] transition-colors">
                +593 (9) 5907 6237
              </a>
            </div>
            <div class="flex items-center gap-3 text-sm">
              <Icon class="text-[#3C1475] w-4 h-4 shrink-0" name="uil:youtube" />
              <a
                href="https://youtube.com/@raymundoycaza"
                target="_blank"
                rel="noopener noreferrer"
                class="text-[#3C1475] hover:text-[#0098ED] transition-colors">
                youtube.com/@raymundoycaza
              </a>
            </div>
          </div>
        </div>

        <!-- Expectativa de respuesta -->
        <div class="bg-[#3C1475]/[0.04] border border-[#3C1475]/15 rounded-2xl px-5 py-4">
          <p class="text-xs font-semibold text-[#3C1475] uppercase tracking-widest mb-1">
            Tiempo de respuesta
          </p>
          <p class="text-sm text-slate-600 leading-relaxed">
            Respondo personalmente en menos de <strong class="text-gray-900">48 horas hábiles</strong>.
            Si es urgente, mencíonalo en tu mensaje.
          </p>
        </div>

      </div>

      <!-- Columna derecha — formulario -->
      <div>
        <Contactform />
      </div>

    </div>
  </Container>

  <!-- ═══ CTA FINAL ═══ -->
  <section class="max-w-2xl mx-auto mt-20 mb-16 px-4 text-center">
    <div class="flex items-center gap-4 mb-6">
      <div class="flex-1 h-px bg-[#3C1475]/10"></div>
      <div class="flex gap-1">
        <span class="w-1.5 h-1.5 rounded-full bg-[#3C1475]/30"></span>
        <span class="w-1.5 h-1.5 rounded-full bg-[#3C1475]/50"></span>
        <span class="w-1.5 h-1.5 rounded-full bg-[#3C1475]/30"></span>
      </div>
      <div class="flex-1 h-px bg-[#3C1475]/10"></div>
    </div>
    <p class="text-lg text-slate-500 leading-relaxed">
      ¿Prefieres explorar primero?
      <a
        href="/blog"
        class="text-[#3C1475] font-medium hover:text-[#0098ED] transition-colors">
        Lee el blog →
      </a>
    </p>
  </section>

</Layout>

