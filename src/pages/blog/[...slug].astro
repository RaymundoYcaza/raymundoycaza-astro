---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import { formatDate } from "@/utils/formatDate";
import TOC from "@components/TOC.astro";
import Aside from "@components/aside.astro";
import { Image } from "astro:assets";

// Generate a new path for every collection entry
export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");
  blogEntries.forEach(e => console.log(e.slug))
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

// Get the entry directly from the prop on render
const { entry } = Astro.props;
const { Content, headings } = await entry.render();

const displayDate = entry.data.updatedDate ?? entry.data.publishDate;

const ogImageUrl = entry.data.cover
  ? new URL(entry.data.cover.src, Astro.site).toString()
  : undefined;

---

<Layout
  title={entry.data.title}
  ogImage={ogImageUrl}
  ogImageAlt={entry.data.coverAlt}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "datePublished": entry.data.publishDate.toISOString(),
    "dateModified": displayDate.toISOString()
  }}>
  <Container>
    <div class="mx-auto max-w-3xl mt-14">
      <span class="text-blue-400 uppercase tracking-wider text-sm font-medium">
        {entry.data.category}
      </span>
      <h1
        class="text-4xl lg:text-5xl font-bold lg:tracking-tight mt-1 lg:leading-tight">
        {entry.data.title}
      </h1>
      <div class="flex gap-2 mt-3 items-center flex-wrap md:flex-nowrap">
        <span class="text-gray-400">
          {entry.data.author}
        </span>
        <span class="text-gray-400">•</span>
      <time
        class="text-gray-400"
        datetime={displayDate.toISOString()}>
        {entry.data.updatedDate ? "Actualizado: " : ""}
        {formatDate(displayDate)}
      </time>
      </div>
    </div>
    <div class="mx-auto max-w-3xl mt-0">
      <div class="w-full md:w-auto flex flex-wrap gap-3">
        {
          entry.data.tags.map((tag) => (
            <span class="text-sm text-gray-500">#{tag}</span>
          ))
        }
      </div>
    </div>
    
    {entry.data.cover && (
      <div class="mx-auto max-w-3xl mt-6">
        <Image
          src={entry.data.cover}
          alt={entry.data.coverAlt}
          width={735}
          class="w-full rounded-xl object-cover"
        />
      </div>
    )}
    <div class="mx-auto prose prose-lg mt-6 max-w-3xl">
      <TOC headings={headings} />
      <Content components={{ Aside }} />
    </div>
    <div class="text-center mt-8">
      <a
        href="/blog"
        class="bg-gray-100 px-5 py-3 rounded-md hover:bg-gray-200 transition"
        >← Regresar al Blog</a
      >
    </div>
  </Container>
</Layout>
