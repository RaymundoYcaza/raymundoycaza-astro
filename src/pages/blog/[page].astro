---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import BlogPostList from "@components/BlogPostList.astro";
import Pagination from "@components/Pagination.astro";

export async function getStaticPaths() {
  const POSTS_PER_PAGE = 10;

  const allPosts = await getCollection("blog", ({ data }) => {
    return !data.draft && data.publishDate < new Date();
  });

  allPosts.sort(
    (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
  );

  const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);

  return Array.from({ length: totalPages - 1 }, (_, i) => {
    const page = i + 2;
    const start = (page - 1) * POSTS_PER_PAGE;
    return {
      params: { page: String(page) },
      props: {
        posts: allPosts.slice(start, start + POSTS_PER_PAGE),
        currentPage: page,
        totalPages,
        prevUrl: page === 2 ? "/blog" : `/blog/${page - 1}`,
        nextUrl: page < totalPages ? `/blog/${page + 1}` : undefined,
      },
    };
  });
}

const { posts, currentPage, totalPages, prevUrl, nextUrl } = Astro.props;
---

<Layout title={`Blog – Página ${currentPage}`}>
  <Container>
    <Sectionhead>
      <Fragment slot="title">Automatiza tus Procesos</Fragment>
      <Fragment slot="desc">
        Descubre cómo la automatización de procesos de negocio puede impulsar <br
        />la eficiencia, reducir costos y liberar tiempo para la innovación.
      </Fragment>
    </Sectionhead>
    <main class="mt-16">
      <BlogPostList posts={posts} />
      <Pagination
        currentPage={currentPage}
        totalPages={totalPages}
        prevUrl={prevUrl}
        nextUrl={nextUrl}
      />
    </main>
  </Container>
</Layout>
