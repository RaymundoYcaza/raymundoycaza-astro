---
import { getCollection } from "astro:content";
import { Picture } from "astro:assets";

const posts = await getCollection("blog", ({ data }) => {
  return !data.draft && data.publishDate < new Date();
});

posts.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const latest = posts.slice(0, 3);

const fmt = new Intl.DateTimeFormat("es-EC", {
  year: "numeric",
  month: "short",
  day: "2-digit",
});
---

<section class="my-24">
  <div class="text-center">
    <h2 class="text-3xl lg:text-4xl font-bold text-gray-900">
      Empieza con estos artículos
    </h2>
    <p class="text-slate-600 mt-3 text-lg max-w-2xl mx-auto">
      Guías prácticas para automatizar, mejorar reportes y recuperar tiempo esta
      semana.
    </p>
  </div>

  <div class="mt-10 grid gap-6 md:grid-cols-3">
    {
      latest.map((post, index) => (
        <a
          href={`/blog/${post.slug}`}
          class="group rounded-2xl border border-[#3C1475]/15 bg-white hover:bg-[#3C1475]/[0.03] shadow-sm hover:shadow-md transition-all duration-200 overflow-hidden">
          <div class="aspect-[16/10] bg-slate-100 overflow-hidden">
            <Picture
              src={post.data.cover}
              alt={post.data.coverAlt}
              sizes="(max-width: 768px) 100vw, 380px"
              widths={[240, 380, 760]}
              width="760"
              height="auto"
              loading={index === 0 ? "eager" : "lazy"}
              decoding={index === 0 ? "sync" : "async"}
              class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-200"
            />
          </div>

          <div class="p-6">
            <div class="flex items-center gap-2 text-xs">
              <span class="uppercase tracking-wider font-semibold text-[#0098ED]">
                {post.data.category}
              </span>
              <span class="text-slate-400">•</span>
              <time
                class="text-slate-500"
                datetime={post.data.publishDate.toISOString()}>
                {fmt.format(post.data.publishDate)}
              </time>
            </div>

            <h3 class="mt-2 text-lg font-bold text-gray-900 leading-snug">
              {post.data.title}
            </h3>

            <p class="mt-3 text-sm text-slate-600 leading-relaxed line-clamp-3">
              {post.data.description ??
                "Guía práctica paso a paso para aplicar hoy mismo."}
            </p>

            <div class="mt-4 text-sm font-semibold text-[#3C1475] group-hover:underline">
              Leer artículo →
            </div>
          </div>
        </a>
      ))
    }
  </div>

  <div class="text-center mt-10">
    <a
      href="/blog"
      class="text-sm font-semibold text-slate-600 hover:text-gray-900 underline-offset-4 hover:underline">
      Ver todos los artículos
    </a>
  </div>
</section>
