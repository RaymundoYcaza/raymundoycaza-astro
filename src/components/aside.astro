---
export interface Props {
  type?: 'note' | 'tip' | 'caution' | 'danger' | 'none';
  title?: string;
}

const { type = 'note', title } = Astro.props as Props;

// Etiquetas por defecto si no se pasa title
const defaultTitles: Record<NonNullable<Props['type']>, string> = {
  note:    'Nota',
  tip:     'Consejo',
  caution: 'Precaución',
  danger:  'Importante',
  none:    'Recuerda',
};

const resolvedTitle = title ?? defaultTitles[type];

// Paleta de colores por tipo
// tip   → morado de marca #3C1475
// note  → azul informativo #0098ED
// caution → ámbar
// danger  → rojo
// none    → gris neutro
const styles: Record<NonNullable<Props['type']>, {
  wrapper: string;
  bar: string;
  icon: string;
  label: string;
  text: string;
}> = {
  tip: {
    wrapper: 'bg-[#3C1475]/[0.06] border border-[#3C1475]/20',
    bar:     'bg-[#3C1475]',
    icon:    'text-[#3C1475]',
    label:   'text-[#3C1475]',
    text:    'text-[#3C1475]/80',
  },
  note: {
    wrapper: 'bg-[#0098ED]/[0.06] border border-[#0098ED]/20',
    bar:     'bg-[#0098ED]',
    icon:    'text-[#0098ED]',
    label:   'text-[#0098ED]',
    text:    'text-[#0098ED]/80',
  },
  caution: {
    wrapper: 'bg-amber-50 border border-amber-200',
    bar:     'bg-amber-400',
    icon:    'text-amber-500',
    label:   'text-amber-600',
    text:    'text-amber-700/80',
  },
  danger: {
    wrapper: 'bg-red-50 border border-red-200',
    bar:     'bg-red-500',
    icon:    'text-red-500',
    label:   'text-red-600',
    text:    'text-red-700/80',
  },
  none: {
    wrapper: 'bg-gray-50 border border-gray-200',
    bar:     'bg-gray-400',
    icon:    'text-gray-500',
    label:   'text-gray-600',
    text:    'text-gray-600/80',
  },
};

// SVG icons
const icons: Record<NonNullable<Props['type']>, { viewBox: string; d: string }> = {
  note: {
    viewBox: '0 0 24 24',
    d: 'M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  tip: {
    viewBox: '0 0 24 24',
    d: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
  },
  caution: {
    viewBox: '0 0 24 24',
    d: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z',
  },
  danger: {
    viewBox: '0 0 24 24',
    d: 'M13 10V3L4 14h7v7l9-11h-7z',
  },
  none: {
    viewBox: '0 0 24 24',
    d: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
  },
};

const s = styles[type];
const { viewBox, d } = icons[type];

// Stroke vs fill: estos iconos son stroke, no fill
const isStroke = true;
---

<aside
  class={`relative overflow-hidden rounded-xl ${s.wrapper} my-6`}
  aria-label={resolvedTitle}>

  <!-- Barra lateral de color -->
  <div class={`absolute left-0 top-0 bottom-0 w-1 ${s.bar} rounded-l-xl`}></div>

  <div class="pl-5 pr-4 py-4">

    <!-- Header -->
    <div class="flex items-center gap-2 mb-2">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox={viewBox}
        width="16"
        height="16"
        class={`w-4 h-4 shrink-0 ${s.icon}`}
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true">
        <path d={d}></path>
      </svg>
      <span class={`text-xs font-bold uppercase tracking-widest ${s.label}`}>
        {resolvedTitle}
      </span>
    </div>

    <!-- Contenido -->
    <div class={`text-sm leading-relaxed ${s.text} [&>p]:mb-0`}>
      <slot />
    </div>

  </div>
</aside>

