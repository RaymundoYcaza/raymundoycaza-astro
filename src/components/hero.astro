---
import { Picture } from "astro:assets";
import Link from "@components/ui/link.astro";
import { Icon } from "astro-icon/components";
import heroImage from "../assets/hero-blog_1772569213236.jpg";
---

<style>
  .hero img {
    max-width: 500px;
  }
</style>

<main
  class="grid lg:grid-cols-2 place-items-center pt-16 pb-8 md:pt-2 md:pb-24 bg-transparent">
  <div class="py-0 md:order-1 hidden md:block bg-transparent">
    <Picture
      src={heroImage}
      alt="Automatizacion que Transforma | Raymundo Ycaza"
      widths={[200, 400, 600]}
      sizes="(max-width: 500px) 100vw, 500px"
      loading="eager"
      formats={["avif", "webp", "jpg"]}
    />
  </div>
  <div class="">
    <h1
      class="text-4xl lg:text-5xl xl:text-6xl font-bold lg:tracking-tight xl:tracking-tighter text-gray-900">
      Deja de perder horas en tareas que se pueden <span class="text-purple-700"
        >automatizar</span
      >
    </h1>
    <p class="text-lg mt-4 text-slate-500 max-w-xl">
      Te enseño a sistematizar tu trabajo con herramientas accesibles <br />
      <strong>sin necesidad de ser técnico</strong>
      <br />
      <strong>para que tengas más tiempo para lo que realmente importa.</strong>
    </p>
    <div class="mt-6 flex flex-col sm:flex-row gap-3">
      <Link
        href="#"
        href="#"
        target="_self"
        class="flex gap-1 items-center justify-center bg-blue-700"
        rel="noopener">
        <Icon class="text-white w-5 h-5" name="bx:bxs-envelope" />

        Quiero automatizar mi trabajo
      </Link>
      <Link
        size="lg"
        style="outline"
        href="/acerca-de"
        class="flex gap-1 items-center justify-center">
        Cómo trabajo
      </Link>
    </div>
  </div>
</main>
