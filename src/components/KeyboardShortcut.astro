---
export interface Props {
  keys: string[];
  title: string;
  description?: string;
}

const { keys, title, description } = Astro.props;
---

<div class="group flex flex-col sm:flex-row items-start sm:items-center gap-4
            bg-[#3C1475]/[0.04] border border-[#3C1475]/15
            hover:bg-[#3C1475]/[0.08] hover:border-[#3C1475]/35
            rounded-2xl px-5 py-4
            shadow-sm hover:shadow-md
            transition-all duration-200 my-3">

  <!-- Teclas -->
  <div class="flex items-center gap-1.5 shrink-0">
    {keys.map((key, index) => (
      <>
        <kbd class="
          inline-flex items-center justify-center
          min-w-[2.25rem] h-9 px-2.5
          bg-white text-gray-700
          border border-gray-300 border-b-[3px]
          rounded-lg
          font-mono text-sm font-semibold
          shadow-sm
          select-none
          transition-all duration-150
          group-hover:border-[#3C1475]/50
          group-hover:text-[#3C1475]
          group-hover:border-b-[#3C1475]/50
        ">
          {key}
        </kbd>
        {index < keys.length - 1 && (
          <span class="text-[#3C1475]/40 text-xs font-bold select-none">+</span>
        )}
      </>
    ))}
  </div>

  <!-- Texto -->
  <div class="flex flex-col min-w-0">
    <span class="text-sm font-semibold text-gray-900 leading-tight">
      {title}
    </span>
    {description && (
      <span class="text-sm text-slate-500 leading-relaxed mt-0.5">
        {description}
      </span>
    )}
  </div>

</div>

