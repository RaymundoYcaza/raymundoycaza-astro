---
interface Props {
  href: string;
  size?: "md" | "lg";
  block?: boolean;
  style?: "outline" | "outlineSoft" | "primary" | "inverted" | "muted";
  class?: string;
  [x: string]: any;
}

const {
  href,
  block,
  size = "lg",
  style = "primary",
  class: className,
  ...rest
} = Astro.props;

const sizes = {
  lg: "px-5 py-2.5",
  md: "px-4 py-2",
};

const base =
  "rounded text-center transition-colors duration-150 focus-visible:ring-2 ring-offset-2 focus-visible:ring-[#3C1475]/25";

const styles = {
  // Outline “fuerte” (tu comportamiento actual)
  outline:
    "border-2 border-[#3C1475] text-[#3C1475] hover:bg-[#3C1475] hover:text-white",

  // Outline “suave” (recomendado para CTA secundario)
  outlineSoft:
    "border-2 border-[#3C1475]/80 text-[#3C1475] bg-transparent hover:bg-[#3C1475]/[0.08] hover:border-[#3C1475] hover:text-[#3C1475]",

  primary:
    "bg-[#3C1475] text-white hover:bg-[#3C1475]/90 border-2 border-transparent",

  inverted:
    "bg-white text-gray-900 hover:bg-gray-50 border-2 border-transparent",

  muted:
    "bg-gray-100 text-gray-900 hover:bg-gray-200 border-2 border-transparent",
};
---

<a
  href={href}
  {...rest}
  class:list={[base, block && "w-full", sizes[size], styles[style], className]}>
  <slot />
</a>
