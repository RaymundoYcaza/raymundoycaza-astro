---
// @ts-ignore
import { Icon } from "astro-icon";

const features = [
  {
    title: "Automatiza sin ser programador",
    description:
      "Te enseño a eliminar tareas repetitivas usando herramientas accesibles, sin necesidad de escribir código complejo.",
    icon: "bx:bxs-briefcase",
  },
  {
    title: "Soluciones que realmente funcionan",
    description:
      "Nada de teoría vacía. Cada solución que comparto ha sido probada en entornos reales con resultados concretos.",
    icon: "bx:bxs-window-alt",
  },
  {
    title: "Herramientas actuales, explicadas fácil",
    description:
      "Trabajo con las plataformas más útiles del momento y te las explico como si estuviéramos frente a frente.",
    icon: "bx:bxs-data",
  },
  {
    title: "Recupera horas de tu semana",
    description:
      "Con el sistema correcto, puedes pasar de 12 horas generando un informe a resolverlo en 2, con datos confiables.",
    icon: "bx:bxs-bot",
  },
  {
    title: "Acompañamiento real, no solo tutoriales",
    description:
      "No solo publico guías: acompaño a personas y equipos en el proceso de transformar su forma de trabajar.",
    icon: "bx:bxs-file-find",
  },
  {
    title: "Procesos que escalan con tu negocio",
    description:
      "Las soluciones que aprenderás están pensadas para crecer contigo, sin depender de herramientas costosas.",
    icon: "bx:bxs-user",
  },
];
---

<div class="mt-16 md:mt-0">
  <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
    Lo que puedes lograr trabajando conmigo
  </h2>
  <p class="text-lg mt-4 text-slate-600">
    Estos son los cambios concretos que mis lectores, alumnos y clientes
    experimentan cuando aplican lo que enseño.
  </p>
</div>

<div class="grid sm:grid-cols-2 md:grid-cols-3 mt-16 gap-16">
  {
    features.map((item) => (
      <div class="flex gap-4 items-start">
        <div class="mt-1 bg-black rounded-full  p-2 w-8 h-8 shrink-0">
          <Icon class="text-white" name={item.icon} />
        </div>
        <div>
          <h3 class="font-semibold text-lg">{item.title}</h3>{" "}
          <p class="text-slate-500 mt-2 leading-relaxed">{item.description}</p>
        </div>
      </div>
    ))
  }
</div>
