---
import { Dropdown as DropdownContainer, DropdownItems } from "astro-navbar";
const { title, lastItem, children } = Astro.props;
---

<li class="relative">
  <DropdownContainer class="group">
    <button
      class="flex items-center gap-1 w-full lg:w-auto lg:px-3 py-2 text-gray-600 hover:text-gray-900">
      <span>{title}</span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="3"
        stroke="currentColor"
        class="w-3 h-3 mt-0.5 group-open:rotate-180 transition-transform duration-200">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path>
      </svg>
    </button>
    <DropdownItems>
      <div
        class:list={[
          "lg:absolute w-full z-10",
          lastItem
            ? "lg:right-0 origin-top-right"
            : "lg:left-0 origin-top-left",
        ]}>
        <div
          class="mt-1 lg:bg-white lg:rounded-2xl lg:shadow-xl lg:border lg:border-gray-100 w-full lg:w-96 flex flex-col p-2 gap-1">
          {
            children.map((item) => (
              <a
                href={item.path}
                class:list={[
                  "flex items-start gap-3 px-3 py-3 rounded-xl transition-colors duration-150",
                  item.featured
                    ? "bg-purple-50 hover:bg-purple-100"
                    : "hover:bg-gray-50",
                ]}>
                <div
                  class:list={[
                    "flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center text-xl",
                    item.featured ? "bg-purple-100" : "bg-gray-100",
                  ]}>
                  {item.icon}
                </div>
                <div class="flex flex-col min-w-0">
                  <span
                    class:list={[
                      "font-semibold text-sm leading-tight",
                      item.featured ? "text-purple-900" : "text-gray-800",
                    ]}>
                    {item.title}
                  </span>
                  {item.description && (
                    <span class="text-xs text-slate-500 mt-0.5 leading-snug">
                      {item.description}
                    </span>
                  )}
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </DropdownItems>
  </DropdownContainer>
</li>
