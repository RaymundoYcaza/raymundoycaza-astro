---
import { getEntry } from "astro:content";
import { Picture } from "astro:assets";

export interface Props {
  slug: string;
  category?: string;
  variant?: "horizontal" | "horizontal-reverse" | "compact" | "card";
  label?: string;
}

const {
  slug,
  category,
  variant = "horizontal",
  label,
} = Astro.props;

const slugParts = slug.split("/");
const resolvedCategory = category ?? slugParts[0];
const resolvedPostName = slugParts[slugParts.length - 1];
const url = `/blog/${resolvedCategory}/${resolvedPostName}`;

const entry = await getEntry("blog", slug);
if (!entry) return null;

const { title, description, cover, coverAlt, category: postCategory } = entry.data;
const displayLabel = label ?? postCategory;
---

{/* ══ HORIZONTAL / HORIZONTAL-REVERSE ══ */}
{(variant === "horizontal" || variant === "horizontal-reverse") && (
  <a
    href={url}
    class:list={[
      "group not-prose flex flex-col sm:flex-row items-stretch gap-0",
      "bg-[#3C1475]/[0.04] border border-[#3C1475]/15",
      "hover:bg-[#3C1475]/[0.08] hover:border-[#3C1475]/30",
      "rounded-2xl overflow-hidden shadow-sm hover:shadow-md",
      "transition-all duration-200 my-6",
      variant === "horizontal-reverse" && "sm:flex-row-reverse",
    ]}>
    <div class="sm:w-2/5 shrink-0 overflow-hidden">
      <Picture
        src={cover}
        alt={coverAlt ?? title}
        widths={[400, 800]}
        sizes="(max-width: 640px) 100vw, 40vw"
        class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-300"
      />
    </div>
    <div class="flex flex-col justify-center gap-2 px-5 py-5">
      {displayLabel && (
        <span class="text-xs font-bold uppercase tracking-widest text-[#3C1475]/70">
          {displayLabel}
        </span>
      )}
      <h3 class="text-base font-bold text-gray-900 group-hover:text-[#3C1475] leading-snug transition-colors">
        {title}
      </h3>
      {description && (
        <p class="text-sm text-slate-500 leading-relaxed line-clamp-2">
          {description}
        </p>
      )}
      <span class="inline-flex items-center gap-1 text-xs font-semibold text-[#3C1475] group-hover:text-[#0098ED] transition-colors mt-1">
        Leer artículo
        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
        </svg>
      </span>
    </div>
  </a>
)}

{/* ══ COMPACT — imagen panorámica corregida ══ */}
{variant === "compact" && (
  <a
    href={url}
    class="group not-prose flex items-center gap-0
           bg-[#3C1475]/[0.04] border border-[#3C1475]/15
           hover:bg-[#3C1475]/[0.08] hover:border-[#3C1475]/30
           rounded-xl overflow-hidden shadow-sm hover:shadow-md
           transition-all duration-200 my-3">

    <!-- Imagen: aspect-video para respetar proporciones 16:9 -->
    <div class="w-28 shrink-0 self-stretch overflow-hidden">
      <Picture
        src={cover}
        alt={coverAlt ?? title}
        widths={[224, 448]}
        sizes="112px"
        class="w-full h-full object-cover group-hover:scale-[1.05] transition-transform duration-300"
      />
    </div>

    <!-- Texto -->
    <div class="flex flex-col gap-0.5 min-w-0 px-4 py-3">
      {displayLabel && (
        <span class="text-[10px] font-bold uppercase tracking-widest text-[#3C1475]/60 truncate">
          {displayLabel}
        </span>
      )}
      <span class="text-sm font-semibold text-gray-900 group-hover:text-[#3C1475] leading-snug transition-colors line-clamp-2">
        {title}
      </span>
      {description && (
        <span class="text-xs text-slate-400 leading-relaxed line-clamp-1 mt-0.5">
          {description}
        </span>
      )}
    </div>

    <!-- Flecha -->
    <svg class="w-4 h-4 shrink-0 text-[#3C1475]/30 group-hover:text-[#3C1475] transition-colors ml-auto mr-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
    </svg>
  </a>
)}

{/* ══ CARD — rectangular vertical ══ */}
{variant === "card" && (
  <a
    href={url}
    class="group not-prose flex flex-col
           bg-white border border-[#3C1475]/15
           hover:border-[#3C1475]/35 hover:shadow-lg
           rounded-2xl overflow-hidden shadow-sm
           transition-all duration-200 my-4">

    <!-- Imagen superior con aspect ratio fijo -->
    <div class="overflow-hidden aspect-video w-full">
      <Picture
        src={cover}
        alt={coverAlt ?? title}
        widths={[400, 800]}
        sizes="(max-width: 640px) 100vw, 400px"
        class="w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-300"
      />
    </div>

    <!-- Contenido -->
    <div class="flex flex-col gap-2 px-5 py-4">
      {displayLabel && (
        <span class="text-[10px] font-bold uppercase tracking-widest text-[#0098ED]">
          {displayLabel}
        </span>
      )}
      <h3 class="text-sm font-bold text-gray-900 group-hover:text-[#3C1475] leading-snug transition-colors line-clamp-2">
        {title}
      </h3>
      {description && (
        <p class="text-xs text-slate-500 leading-relaxed line-clamp-2">
          {description}
        </p>
      )}
      <span class="inline-flex items-center gap-1 text-xs font-semibold text-[#3C1475] group-hover:text-[#0098ED] transition-colors mt-auto pt-1">
        Leer artículo
        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
        </svg>
      </span>
    </div>
  </a>
)}

