---
// Solo el overlay, sin botón
---

<div
  id="search-modal"
  class="fixed inset-0 z-50 hidden items-start justify-center pt-20 px-4"
  role="dialog"
  aria-modal="true"
  aria-label="Buscador">

  <div id="search-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

  <div class="relative w-full max-w-2xl bg-white rounded-2xl shadow-2xl overflow-hidden">
    <div class="flex items-center justify-between px-5 pt-4 pb-2 border-b border-gray-100">
      <span class="text-sm font-medium text-gray-500">Buscar en el blog</span>
      <button
        id="search-close"
        aria-label="Cerrar buscador"
        class="text-gray-400 hover:text-gray-600 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div class="p-4">
      <div id="search-widget"></div>
    </div>

    <div class="px-5 py-2 border-t border-gray-100 flex gap-3 text-xs text-gray-400">
      <span><kbd class="font-mono bg-gray-100 px-1.5 py-0.5 rounded">Esc</kbd> para cerrar</span>
      <span><kbd class="font-mono bg-gray-100 px-1.5 py-0.5 rounded">↑↓</kbd> para navegar</span>
    </div>
  </div>
</div>

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />

<script>
document.addEventListener('DOMContentLoaded', () => {
  let pagefindLoaded = false;

  const modal = document.getElementById('search-modal')!;
  const closeBtn = document.getElementById('search-close')!;
  const backdrop = document.getElementById('search-backdrop')!;

  function openModal() {
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';

    if (!pagefindLoaded) {
      pagefindLoaded = true;
      const script = document.createElement('script');
      script.src = '/pagefind/pagefind-ui.js';
      script.onload = () => {
        // @ts-ignore
        new PagefindUI({
          element: '#search-widget',
          showSubResults: true,
          translations: {
            placeholder: 'Buscar artículos...',
            zero_results: 'Sin resultados para "[SEARCH_TERM]"',
          },
        });
        setTimeout(() => {
          const input = modal.querySelector('input');
          input?.focus();
        }, 50);
      };
      document.body.appendChild(script);
    } else {
      setTimeout(() => {
        const input = modal.querySelector('input');
        input?.focus();
      }, 50);
    }
  }

  function closeModal() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
  }

  // Escucha todos los triggers por clase (pueden ser varios)
  document.querySelectorAll('.search-trigger').forEach(trigger => {
    trigger.addEventListener('click', openModal);
  });

  closeBtn.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      openModal();
    }
  });
});
</script>

