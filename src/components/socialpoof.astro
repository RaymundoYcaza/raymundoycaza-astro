---
const stats = [
  {
    value: "+3,000",
    label: "profesionales ya optimizando su trabajo",
    icon: "👥",
  },
  {
    value: "+200",
    label: "artículos y tutoriales publicados",
    icon: "📚",
  },
  {
    value: "0",
    label: "conocimientos técnicos previos necesarios",
    icon: "🚀",
  },
];
---

<div class="mt-20 mb-4">
  <div
    class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-center max-w-3xl mx-auto">
    {
      stats.map((stat) => (
        <div class="flex flex-col items-center gap-1">
          <span class="text-3xl">{stat.icon}</span>
          <span class="text-3xl font-bold text-purple-700">{stat.value}</span>
          <span class="text-sm text-slate-500">{stat.label}</span>
        </div>
      ))
    }
  </div>
</div>
